@startuml
!theme plain
!include <C4/C4_Context>

title E2E Test Suite — C4 Context Diagram

Person(developer, "Developer", "Writes and runs E2E tests\nlocally and in CI")

System(e2eSuite, "E2E Test Suite", "Playwright-based tests across\n6 apps targeting 732 tests")

System(crownCommerce, "CrownCommerce Platform", "Next.js app with storefront,\nadmin, and teams routes")

System_Ext(ci, "GitHub Actions", "CI/CD pipeline running\ntests on every push/PR")

System_Ext(reportServer, "HTML Report", "Playwright HTML reporter\nwith traces and screenshots")

Rel(developer, e2eSuite, "Writes & runs tests", "npx playwright test")
Rel(e2eSuite, crownCommerce, "Tests against", "HTTP localhost:3000")
Rel(ci, e2eSuite, "Triggers test runs", "workflow dispatch")
Rel(e2eSuite, reportServer, "Generates reports", "playwright-report/")

@enduml
