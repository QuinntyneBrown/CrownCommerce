@startuml c4-container
!theme plain
!include <C4/C4_Container>

title CrownCommerce — Runtime Containers (L2-035, L2-041)

Person(user, "User", "Customer, Admin, or Team Member")

System_Boundary(cc, "CrownCommerce Platform") {
    Container(browser, "Browser", "Web app", "Renders client components and submits interactive requests")
    Container(proxy, "Request Boundary", "proxy.ts", "Brand detection, coarse redirects, request-header enrichment")
    Container(server_render, "Server Render Layer", "Next.js App Router", "Pages, layouts, Server Components, streaming HTML")
    Container(api, "Public API Layer", "Route Handlers", "Public JSON endpoints under /api/*")
    Container(apiclient, "API Client Library", "TypeScript, lib/api/", "Browser-first typed clients for /api/*")
    Container(services, "Domain Service Layer", "TypeScript, lib/domains/*", "Shared queries, mutations, validation, cache invalidation")
}

ContainerDb(pg, "PostgreSQL", "10 schemas", "catalog, orders, identity, content,\nnewsletter, chat, inquiries,\nscheduling, crm, notifications")

System_Ext(cdn, "Vercel CDN", "Static assets and edge caching")

Rel(user, browser, "Interacts", "HTTPS")
Rel(browser, proxy, "Requests pages and APIs", "HTTPS")
Rel(proxy, server_render, "Forwards page requests")
Rel(browser, apiclient, "Interactive client code imports")
Rel(apiclient, api, "Calls public endpoints", "/api/{domain}/*")
Rel(server_render, services, "Direct function calls")
Rel(api, services, "Delegates to shared domain logic")
Rel(services, pg, "Drizzle queries")
Rel(server_render, cdn, "Streams HTML and assets")

@enduml
