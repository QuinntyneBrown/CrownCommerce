@startuml seq-page-render
!theme plain

title Storefront Page Rendering — Direct Server Data Path (L2-042, L2-060)

participant "Browser" as browser
participant "proxy.ts" as proxy
participant "Next.js Page\napp/(storefront)/page.tsx" as page
participant "getBrand()\nlib/theme" as brand
participant "Catalog Queries\nlib/domains/catalog/queries.ts" as catalog
participant "Content Queries\nlib/domains/content/queries.ts" as content
database "PostgreSQL" as db
participant "Features\nlib/features/*.tsx" as features
participant "Components\ncomponents/*.tsx" as components

browser -> proxy: GET /
activate proxy
proxy --> page: Forward request with x-brand header
deactivate proxy

activate page

page -> brand: getBrand()
brand --> page: { id: "origin", ... }

page -> catalog: listFeaturedProducts()
page -> content: listHomepageTestimonials()
note right of page: Parallel queries\nvia Promise.all()

catalog -> db: SELECT projected columns\nFROM catalog.products LIMIT 8
content -> db: SELECT projected columns\nFROM content.testimonials

db --> catalog: Product[]
db --> content: Testimonial[]
catalog --> page: Product[]
content --> page: Testimonial[]

page -> features: <ProductGrid\n  products={products.slice(0,8)}\n  title="Featured Products" />
activate features
features -> components: <ProductCard /> × N
components --> features: Rendered cards
features --> page: Product grid HTML
deactivate features

page -> features: <TestimonialsSection\n  testimonials={testimonials} />
activate features
features -> components: <TestimonialCard /> × N
features --> page: Testimonials HTML
deactivate features

page -> features: <NewsletterSignup\n  brandTag="origin" />
activate features
features -> components: <EmailSignup />\n<SectionHeader />
features --> page: Newsletter section HTML
deactivate features

page --> browser: Streamed HTML

deactivate page

note right of page
  Server render path never calls
  the app's own /api/* endpoints.

  Read-heavy queries use tagged caches.
  Slow subtrees stream behind loading.tsx
  or explicit Suspense boundaries.
end note

@enduml
