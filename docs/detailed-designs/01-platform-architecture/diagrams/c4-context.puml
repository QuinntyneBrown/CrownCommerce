@startuml c4-context
!theme plain
!include <C4/C4_Context>

title CrownCommerce Platform — System Context (L2-035, L2-054)

Person(customer, "Customer", "Browses products, places orders\nvia originhair.com or manehaus.com")
Person(admin, "Admin", "Manages products, orders,\ncontent, CRM via /admin/*")
Person(team, "Team Member", "Collaborates via /teams/*\nchat, meetings, scheduling")

System(cc, "CrownCommerce Platform", "Next.js 15 modular monolith serving multi-brand premium hair e-commerce with 11 isolated domain modules")

System_Ext(cdn, "Vercel CDN", "Static asset delivery and edge caching")
SystemDb_Ext(pg, "PostgreSQL Database", "Single instance with 11 isolated pgSchema domains")

Rel(customer, cc, "Browses, orders", "HTTPS")
Rel(admin, cc, "Manages data", "HTTPS")
Rel(team, cc, "Collaborates", "HTTPS")
Rel(cc, pg, "Reads/writes domain data", "Drizzle ORM / SQL")
Rel(cc, cdn, "Serves static assets", "HTTPS")

@enduml
