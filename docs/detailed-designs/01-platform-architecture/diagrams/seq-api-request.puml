@startuml seq-api-request
!theme plain

title API Request Lifecycle — Browser Mutation via Route Handler (L2-035, L2-041)

actor "Browser" as browser
participant "API Client\n(lib/api/*)" as client
participant "Route Handler\napp/api/catalog/\nproducts/route.ts" as handler
participant "Validation + Auth\n(zod / withAdmin)" as guard
participant "Domain Service\nlib/domains/catalog/\nmutations.ts" as service
database "PostgreSQL" as db

browser -> client: createProduct(data)
activate client

client -> handler: POST /api/catalog/products
activate handler

handler -> guard: Parse body + verify admin session
activate guard

guard --> handler: Validated input
deactivate guard

handler -> service: createProduct(input)
activate service

service -> db: INSERT INTO catalog.products ...
activate db

db --> service: Product row
deactivate db

service --> handler: Product DTO
deactivate service

handler --> client: 201 Created + JSON body
deactivate handler

client --> browser: Promise<Product>
deactivate client

== Error Path (L2-060) ==

browser -> client: createProduct(data)
activate client

client -> handler: POST /api/catalog/products
activate handler

handler -> guard: Parse body + verify admin session
activate guard

guard --> handler: 400 Validation error\nor 401/403 auth failure
deactivate guard

handler --> client: Structured JSON error
deactivate handler

client --> browser: throws Error
deactivate client

note right of browser
  Client surfaces render an explicit
  form error or ErrorState.

  Server Components do not use this path.
end note

@enduml
