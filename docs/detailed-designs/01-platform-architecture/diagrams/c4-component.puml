@startuml c4-component
!theme plain
!include <C4/C4_Component>

title CrownCommerce — Component-Level Architecture (L2-040, L2-041, L2-042)

Container_Boundary(app, "Application") {
    Component(proxy, "Request Boundary", "proxy.ts", "Hostname -> brand, coarse redirects,\nupstream request headers")
    Component(pages, "Pages & Layouts", "app/**/page.tsx, layout.tsx", "Server-first composition and parallel data loading")
    Component(server_actions, "Server Actions", "app/**/actions.ts", "First-party mutations with cache invalidation")
    Component(features, "Features Library", "lib/features/*.tsx", "Composition and localized interactivity")
    Component(ui_components, "UI Components", "components/ui/*.tsx", "Low-level presentational primitives")
    Component(custom_components, "Custom Components", "components/*.tsx", "Domain UI pieces such as ProductCard\nand EmailSignup")
    Component(api_clients, "API Client Library", "lib/api/*.ts", "Browser-first typed clients for /api/*")
    Component(route_handlers, "Route Handlers", "app/api/**/route.ts", "Public JSON endpoints")
    Component(domain_services, "Domain Services", "lib/domains/**", "Queries, mutations, validation,\nauthorization hooks, cache invalidation")
    Component(db_layer, "Database Layer", "lib/db/**", "Drizzle schema modules and db instance")
}

Rel(proxy, pages, "Forwards page requests")
Rel(pages, domain_services, "Reads directly from")
Rel(pages, features, "Composes")
Rel(features, ui_components, "Renders")
Rel(features, custom_components, "Renders")
Rel(server_actions, domain_services, "Calls")
Rel(api_clients, route_handlers, "HTTP")
Rel(route_handlers, domain_services, "Delegates to")
Rel(domain_services, db_layer, "Queries/mutates")

@enduml
