@startuml class_diagram
!theme plain
skinparam classAttributeIconSize 0
skinparam classFontSize 12
skinparam packageFontSize 14

title Content Management System — Data Model
caption All entities in pgSchema("content") — lib/db/schema/content.ts

package "content schema" {

    class Page <<content.pages>> {
        +id: UUID <<PK, auto>>
        +title: VARCHAR(255) <<NOT NULL>>
        +slug: VARCHAR(255) <<NOT NULL, UNIQUE>>
        +body: TEXT <<NOT NULL>>
        +created_at: TIMESTAMP <<NOT NULL, DEFAULT NOW>>
    }

    class FAQ <<content.faqs>> {
        +id: UUID <<PK, auto>>
        +question: TEXT <<NOT NULL>>
        +answer: TEXT <<NOT NULL>>
        +category: VARCHAR(100) <<nullable>>
    }

    class Testimonial <<content.testimonials>> {
        +id: UUID <<PK, auto>>
        +quote: TEXT <<NOT NULL>>
        +author: VARCHAR(255) <<NOT NULL>>
        +rating: INTEGER <<NOT NULL>>
        +location: VARCHAR(255) <<nullable>>
    }

    class GalleryImage <<content.gallery_images>> {
        +id: UUID <<PK, auto>>
        +url: VARCHAR(500) <<NOT NULL>>
        +alt_text: VARCHAR(255) <<nullable>>
        +category: VARCHAR(100) <<nullable>>
    }

    class HeroContent <<content.hero_content>> {
        +id: UUID <<PK, auto>>
        +title: VARCHAR(255) <<NOT NULL>>
        +subtitle: TEXT <<nullable>>
        +cta_text: VARCHAR(100) <<nullable>>
        +cta_link: VARCHAR(255) <<nullable>>
        +image_url: VARCHAR(500) <<nullable>>
    }

    class TrustBarItem <<content.trust_bar_items>> {
        +id: UUID <<PK, auto>>
        +icon: VARCHAR(100) <<NOT NULL>>
        +text: VARCHAR(255) <<NOT NULL>>
        +description: TEXT <<nullable>>
    }
}

note bottom of Page
  Slugs: about, hair-care-guide,
  shipping-info, returns,
  ambassador-program
end note

note bottom of FAQ
  Categories: General,
  Products, Orders
end note

note bottom of Testimonial
  Rating: 1-5 stars
  Displayed via TestimonialCard
end note

@enduml
