@startuml class_diagram
!theme plain

title Design System — Brand & Theme Data Model (L2-039, L2-058)

enum Brand {
    origin
    mane-haus
}

class BrandConfig {
    +id: Brand
    +name: string
    +tagline: string
    +domain: string
    +aesthetic: string
}

class DesignTokens <<CSS Variables>> {
    --color-background: hex
    --color-foreground: hex
    --color-accent: hex
    --color-accent-foreground: hex
    --color-muted: hex
    --color-muted-foreground: hex
    --color-card: hex
    --color-card-foreground: hex
    --color-border: hex
    --color-input: hex
    --color-ring: hex
    --color-destructive: hex
    --font-heading: font-stack
    --font-body: font-stack
    --radius-sm: rem
    --radius-md: rem
    --radius-lg: rem
    --radius-xl: rem
}

class HeroContent {
    +id: UUID
    +title: string
    +subtitle: string
    +ctaText: string
    +ctaLink: string
    +imageUrl: string
}

class TrustBarItem {
    +id: UUID
    +icon: string
    +text: string
    +description: string
}

BrandConfig --> Brand : id
BrandConfig --> DesignTokens : resolves to
HeroContent --> BrandConfig : configured per brand
TrustBarItem --> BrandConfig : configured per brand

@enduml
